# TeleAgent2API — OpenAI-compatible proxy for TeleAgent

# === TeleAgent Auth Parameters (Required) ===
TELEAGENT_TOKEN=your_teleagent_jwt_token_here
TELEAGENT_INSTALL_ID=your_install_id_here
TELEAGENT_DEVICE_ID=your_device_id_here

# === API Key (Client Authentication) ===
# This is the API Key your clients will use to access teleagent2api
API_KEY=sk-custom-your-key

# === Server Configuration ===
TELEAGENT2API_LISTEN=:10000

# === Optional Overrides ===
# TELEAGENT_BASE_URL=https://agent.teleai.com.cn
# TELEAGENT_UPSTREAM_KEY=sk-qvp4m6h9g20uM6PgYP7E
# TELEAGENT_APP_VERSION=2.0.0
# TELEAGENT_MODELS=chat-lite,chat-pro,chat-flash
# TELEAGENT_TIMEOUT=20m
# TELEAGENT_CHUNK_TIMEOUT=15m
# TELEAGENT_LOG_LEVEL=info
# TELEAGENT_LOG_FORMAT=text
# TELEAGENT_RETRY_COUNT=0
# TELEAGENT_EMPTY_RETRY_COUNT=2
